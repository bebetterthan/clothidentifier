# ClothBot — Local Development Configuration
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# ── Inference ─────────────────────────────────────────────────
MODEL_PATH=./best.onnx
LABELS_PATH=./labels.txt
CONF_THRESHOLD=0.75

# ONNX inference threads (0 = auto: min(cpu_count, 4))
# Set to 2 for small cloud VMs, leave 0 for local dev
INTRA_OP_NUM_THREADS=0

# ── Fold pipeline ─────────────────────────────────────────────
FOLD_ENABLED=true

# ── Size estimation ───────────────────────────────────────────
SIZE_ESTIMATION_ENABLED=true
SIZE_DEBUG_MODE=false
# Path to calibration config (auto-created by /calibrate or calibration.py)
CONFIG_PATH=./config.json

# ── MQTT (disable for local dev — no broker needed) ───────────
MQTT_ENABLED=false
# MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_USER=clothbot
# MQTT_PASSWORD=

# ── Server ────────────────────────────────────────────────────
# HOST and PORT are read by run.sh, not by app.py directly
HOST=127.0.0.1
PORT=8000
